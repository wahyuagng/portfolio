{
    "name": "@tesseract-react-boilerplate/vite-ts",
    "author": "Tesseract",
    "version": "1.0.2",
    "description": "Vite & TypeScript",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "start": "vite preview",
        "build": "tsc && vite build",
        "build:prod": "NODE_OPTIONS='--max-old-space-size=4096' tsc && vite build",
        "build:memory": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
        "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
        "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
        "lint:print": "npx eslint --print-config eslint.config.mjs > eslint-show-config.json",
        "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
        "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
        "fix:all": "npm run lint:fix && npm run fm:fix",
        "clean": "rm -rf node_modules .next out dist build",
        "re:dev": "yarn clean && yarn install && yarn dev",
        "re:build": "yarn clean && yarn install && yarn build",
        "re:build-npm": "npm run clean && npm install && npm run build",
        "tsc:dev": "yarn dev & yarn tsc:watch",
        "tsc:watch": "tsc --noEmit --watch",
        "tsc:print": "npx tsc --showConfig",
        "locales:update": "i18next --config src/locales/i18n-parser.config.mjs"
    },
    "engines": {
        "node": ">=20"
    },
    "packageManager": "yarn@1.22.22",
    "dependencies": {
        "@emotion/cache": "^11.14.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@fontsource-variable/dm-sans": "^5.2.6",
        "@fontsource-variable/inter": "^5.2.6",
        "@fontsource-variable/nunito-sans": "^5.2.6",
        "@fontsource-variable/public-sans": "^5.2.6",
        "@fontsource/barlow": "^5.2.6",
        "@iconify/react": "^6.0.0",
        "@mui/material": "^7.1.2",
        "@mui/stylis-plugin-rtl": "^7.1.0",
        "@mui/x-data-grid": "^8.5.3",
        "@mui/x-date-pickers": "^8.5.3",
        "dayjs": "^1.11.13",
        "es-toolkit": "^1.39.3",
        "firebase": "^11.10.0",
        "framer-motion": "^12.18.1",
        "i18next": "^25.2.1",
        "i18next-browser-languagedetector": "^8.2.0",
        "i18next-resources-to-backend": "^1.2.1",
        "minimal-shared": "^1.0.15",
        "nprogress": "^0.2.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-i18next": "^15.5.3",
        "react-router": "^7.6.2",
        "react-router-dom": "^7.7.1",
        "simplebar-react": "^3.3.0",
        "sonner": "^2.0.5",
        "stylis": "^4.3.6",
        "ua-parser-js": "^2.0.4"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.0.0",
        "@rollup/rollup-linux-x64-musl": "^4.0.0",
        "@rollup/rollup-linux-arm64-gnu": "^4.0.0",
        "@rollup/rollup-linux-arm64-musl": "^4.0.0",
        "@swc/core-linux-x64-gnu": "^1.0.0",
        "@swc/core-linux-x64-musl": "^1.0.0",
        "@swc/core-linux-arm64-gnu": "^1.0.0",
        "@swc/core-linux-arm64-musl": "^1.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.29.0",
        "@types/node": "^24.0.3",
        "@types/nprogress": "^0.2.3",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@types/stylis": "^4.2.7",
        "@typescript-eslint/parser": "^8.34.1",
        "@vitejs/plugin-react-swc": "^3.10.2",
        "eslint": "^9.29.0",
        "eslint-import-resolver-typescript": "^4.4.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-perfectionist": "^4.15.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-unused-imports": "^4.1.4",
        "globals": "^16.2.0",
        "i18next-parser": "^9.3.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.34.1",
        "vite": "^6.3.5",
        "vite-plugin-checker": "^0.9.3"
    }
}
